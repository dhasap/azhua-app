<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.azhua.ext.anichin"
    android:versionCode="4"
    android:versionName="2.0.2" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="34" />

    <!-- Izin internet murni untuk scraping -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:extractNativeLibs="false"
        android:label="AzHua Ext: Anichin"
        android:supportsRtl="true" >

        <!-- SEGEL PENGENAL: Nama kelas utama ekstensi ini -->
        <meta-data
            android:name="azhua.extension.class"
            android:value="com.azhua.ext.anichin.AnichinSource" />

        <!-- 📡 PEMANCAR SINYAL: Marker activity agar Core App bisa mendeteksi ekstensi -->
        <activity
            android:name="com.azhua.ext.anichin.ExtensionMarkerActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="azhua.intent.action.EXTENSION" />
            </intent-filter>
        </activity>
    </application>

</manifest>